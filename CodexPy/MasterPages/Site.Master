<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="CodexPy.MasterPages.SiteMaster" %>

<!DOCTYPE html>
<html>
<head runat="server">
    <title><asp:ContentPlaceHolder ID="TitlePH" runat="server">CodexPy</asp:ContentPlaceHolder></title>
    <link rel="stylesheet" href="<%= ResolveUrl("~/Content/site.css") %>" />
    <asp:ContentPlaceHolder ID="HeadExtra" runat="server" />
</head>
<body>
    <form id="form1" runat="server">
        <div class="app-shell">

            <aside class="sidebar">
                <a href="<%= ResolveUrl("~/User/Dashboard.aspx") %>" class="logo" style="text-decoration:none; color:inherit;">
                    <span style="width:26px;height:26px;border-radius:7px;background:var(--ink);color:var(--py-yellow);display:grid;place-items:center;font-family:var(--font-mono);font-weight:700;font-size:14px;">&lt;/</span>
                    Codex<span class="py">Py</span>
                </a>

                <h6>Learn</h6>
                <a href="<%= ResolveUrl("~/User/Dashboard.aspx") %>" class='<%= IsActive("Dashboard.aspx") %>'>Dashboard</a>
                <a href="<%= ResolveUrl("~/User/Modules.aspx") %>" class='<%= IsActive("Modules.aspx") %>'>All Modules</a>
                <a href="<%= ResolveUrl("~/User/Progress.aspx") %>" class='<%= IsActive("Progress.aspx") %>'>My Progress</a>

                <h6>Account</h6>
                <a href="<%= ResolveUrl("~/User/Profile.aspx") %>" class='<%= IsActive("Profile.aspx") %>'>Profile</a>

                <div style="margin-top:auto;padding-top:16px;border-top:1px solid var(--border)">
                    <a href="<%= ResolveUrl("~/Auth/Logout.aspx") %>" class="nav-item">Log out</a>
                </div>
            </aside>

            <div class="app-main">
                <div class="topbar">
                    <div class="crumbs">
                        <a href="<%= ResolveUrl("~/User/Dashboard.aspx") %>" style="color:inherit; text-decoration:none;">CodexPy</a>
                        <span style="margin: 0 8px">/</span>
                        <strong><asp:ContentPlaceHolder ID="CrumbPH" runat="server">Home</asp:ContentPlaceHolder></strong>
                    </div>
                    <div class="actions">
                        <a href="<%= ResolveUrl("~/User/Profile.aspx") %>" style="display:flex;align-items:center;gap:10px;padding:4px 10px 4px 4px;border-radius:999px;background:var(--bg-sunk); text-decoration:none; color:inherit;" title="View profile">
                            <div class="avatar" style="width:28px;height:28px;font-size:11px">
                                <asp:Literal ID="UserInitials" runat="server" Text="?" />
                            </div>
                            <span style="font-size:13px;font-weight:500">
                                <asp:Literal ID="UserName" runat="server" Text="Learner" />
                            </span>
                        </a>
                    </div>
                </div>

                <asp:ContentPlaceHolder ID="MainContent" runat="server" />
            </div>

        </div>
    </form>
</body>
</html>
